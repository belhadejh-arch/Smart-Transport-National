{
  "expo": {
    "name": "NQL DZ",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2C6B7F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nqldz.app"
    },
    "android": {
      "package": "com.nqldz.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#2C6B7F"
      },
      "edgeToEdgeLayoutEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "output": "single",
      "name": "NQL DZ — منصة النقل الذكية في الجزائر",
      "shortName": "NQL DZ",
      "description": "NQL DZ — المنصة الوطنية الذكية للنقل في الجزائر. ادفع رحلاتك ببطاقة QR ذكية، تابع رصيدك، واشحن من أقرب موزع.",
      "lang": "ar",
      "themeColor": "#2C6B7F",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NQL DZ to access the camera for scanning QR codes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NQL DZ to access your photos to upload card documents.",
          "cameraPermission": "Allow NQL DZ to use the camera to take document photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
